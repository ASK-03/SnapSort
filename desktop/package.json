{
  "name": "snapsort",
  "private": true,
  "version": "3.0.10",
  "description": "AI-powered local photo manager",
  "author": "SnapSort Team <snapsort@ask03.in>",
  "homepage": "https://github.com/ASK-03/SnapSort",
  "repository": {
    "type": "git",
    "url": "https://github.com/ASK-03/SnapSort.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.snapsort.app",
    "productName": "SnapSort",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "icon": "build/icon.png",
      "category": "Graphics"
    },
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend",
        "filter": [
          "api",
          "api.exe"
        ]
      },
      {
        "from": "../models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "axios": "^1.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-virtuoso": "^4.18.9",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.21.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "wait-on": "^9.0.10"
  }
}